# =================================================================
# Framework de Segurança - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas chaves de API
# =================================================================

# Autenticação HTTP Basic (OBRIGATÓRIO EM PRODUÇÃO)
# Se APP_PASSWORD estiver vazio, a auth fica desabilitada (modo dev local).
APP_USERNAME=admin
APP_PASSWORD=

# VirusTotal API Key
# Obtenha em: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# MetaDefender (OPSWAT) API Key
# Obtenha em: https://metadefender.opswat.com/account
METADEFENDER_API_KEY=


# Configurações gerais
MAX_FILE_SIZE_MB=32
UPLOAD_DIR=uploads

# Cache / Histórico
# Caminho do banco SQLite. Em produção (Render free) é efêmero.
DATABASE_PATH=data/scans.db
# TTL do cache em horas (0 = sempre re-scaneia)
CACHE_TTL_HOURS=24

# LLM Analyst (opcional)
# Quando configurado, Claude lê o relatório e escreve uma análise em português.
# Obtenha sua chave em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Modelo: claude-haiku-4-5 (recomendado, ~$0.003/scan) ou claude-sonnet-4-6 (~$0.03/scan)
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=1500
